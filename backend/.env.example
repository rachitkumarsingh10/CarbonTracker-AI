# Database Configuration
DATABASE_URL=postgresql://carbontracker:carbontracker_password@localhost:5432/carbontracker_db

# JWT Configuration
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# IBM watsonx.ai Configuration (Primary LLM)
IBM_WATSONX_API_KEY=your-ibm-watsonx-api-key
IBM_WATSONX_PROJECT_ID=your-project-id
IBM_WATSONX_URL=https://us-south.ml.cloud.ibm.com
IBM_WATSONX_MODEL=ibm/granite-13b-chat-v2

# Ollama Configuration (Fallback LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ChromaDB Configuration
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION_NAME=sustainability_knowledge

# OCR Configuration
TESSERACT_PATH=/usr/bin/tesseract
TESSERACT_LANG=eng

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
CORS_ALLOW_CREDENTIALS=true

# Application Configuration
APP_NAME=CarbonTracker AI
APP_VERSION=1.0.0
DEBUG=true
LOG_LEVEL=INFO

# File Upload Configuration
MAX_UPLOAD_SIZE=10485760
UPLOAD_DIR=./uploads
ALLOWED_EXTENSIONS=pdf,png,jpg,jpeg

# Email Configuration (Optional - for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@carbontracker.ai

# Redis Configuration (Optional - for caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ML Model Configuration
ML_MODEL_PATH=./app/ml/models
PREDICTION_HORIZON_MONTHS=6

# Carbon Emission Factors (kg CO2)
ELECTRICITY_FACTOR=0.92
CAR_FACTOR=0.404
PUBLIC_TRANSPORT_FACTOR=0.089
FLIGHT_FACTOR=0.255
MEAT_DIET_FACTOR=7.2
VEGETARIAN_DIET_FACTOR=4.5
VEGAN_DIET_FACTOR=2.9